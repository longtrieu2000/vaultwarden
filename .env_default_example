# Lắng nghe trên port nào ở host
PORT=8080

# Kích hoạt WebSocket (cần thiết cho Bitwarden clients đồng bộ dữ liệu theo thời gian thực)
WEBSOCKET_ENABLED=true

# Không cho phép đăng ký người dùng mới (đặt thành true nếu muốn mở cho mọi người đăng ký)
SIGNUPS_ALLOWED=false

# Tắt tính năng mời người dùng
INVITATIONS_ALLOWED=false

# ----------------------------------------------------
# (Tùy chọn) Cấu hình SMTP để gửi email (Ví dụ với Gmail)
# ----------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_FROM=your-email@gmail.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ----------------------------------------------------
# (Tùy chọn) Cấu hình Admin Token để truy cập trang quản trị (/admin)
# ----------------------------------------------------
# Khuyến nghị tạo bằng lệnh: openssl rand -base64 48
# ADMIN_TOKEN=your_secure_admin_token_here

# ----------------------------------------------------
# (Tùy chọn) Tên domain của bạn (nếu có sử dụng reverse proxy và HTTPS)
# ----------------------------------------------------
# DOMAIN=https://vault.example.com
